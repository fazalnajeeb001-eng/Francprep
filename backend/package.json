{
  "name": "francprep-backend",
  "version": "1.0.0",
  "description": "FrancPrep TCF/TEF Canada API Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node server.ts",
    "build": "npx tsc && node -e \"const fs = require('fs'); const path = require('path'); fs.mkdirSync('dist/src/schemas', { recursive: true }); fs.readdirSync('src/schemas').forEach(f => fs.copyFileSync(path.join('src/schemas', f), path.join('dist/src/schemas', f)))\"",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "seed": "npx ts-node src/scripts/seedCurriculum.ts"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "stripe": "^14.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "mongodb-memory-server": "^11.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
