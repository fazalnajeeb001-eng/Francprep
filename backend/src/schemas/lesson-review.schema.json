{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://francprep.com/schemas/lesson-review.schema.json",
  "title": "FrancPrep Lesson 8 - Chapter Review & Mini-Assessment",
  "description": "Shape for every chapter's Lesson 8. Structurally different from both Standard lessons and Lesson 7: consolidates the whole chapter's vocabulary and grammar, adds a Can-Do review mapped to lessons, mixed practice exercises, a formal DELF/DALF-style Mini-Assessment with scored sections, and self-reflection prompts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lessonId", "chapterId", "level", "title", "anchorSkill", "durationMinutes",
    "objectives", "grammarFocus", "vocabularyFocus",
    "vocabularyBank", "grammarSummary", "canDoReview", "mixedPracticeExercises",
    "assessment", "selfReflection", "completionSummary"
  ],
  "properties": {
    "lessonId": { "type": "string" },
    "chapterId": { "type": "string" },
    "level": { "type": "string", "enum": ["A0", "A1", "A2", "B1", "B2", "C1", "C2"] },
    "title": { "type": "string" },
    "anchorSkill": { "type": "string", "const": "review" },
    "durationMinutes": { "type": "integer", "minimum": 5, "maximum": 90 },
    "objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "grammarFocus": { "type": "string" },
    "vocabularyFocus": { "type": "string" },

    "vocabularyBank": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "cumulativeNote"],
      "description": "Full consolidated vocabulary list for the chapter, plus the mandatory duplication/polysemy note.",
      "properties": {
        "items": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "cumulativeNote": { "type": "string", "minLength": 1, "description": "Must explicitly confirm no duplication against prior chapters and flag any deliberate polysemy cases." }
      }
    },

    "grammarSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "content": { "type": "string", "minLength": 1, "description": "Full consolidated reference - conjugation tables, rule summaries, etc., rendered as structured text/markdown tables." }
      }
    },

    "canDoReview": {
      "type": "array",
      "minItems": 1,
      "description": "Maps each chapter can-do statement to the lesson(s) that taught it.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "lessonRef"],
        "properties": {
          "statement": { "type": "string", "minLength": 1 },
          "lessonRef": { "type": "string", "description": "e.g. 'Lesson 1' or 'Lessons 2-3'" }
        }
      }
    },

    "mixedPracticeExercises": {
      "type": "object",
      "additionalProperties": false,
      "required": ["questions"],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/question" }
        }
      }
    },

    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["examStyle", "sections"],
      "description": "The formal DELF/DALF-style mini-assessment.",
      "properties": {
        "examStyle": { "type": "string", "description": "e.g. 'DELF A1', 'DELF A2', 'DELF B1', 'DELF B2', 'DALF C1', 'DALF C2'" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "skill", "points", "instructions"],
            "properties": {
              "title": { "type": "string" },
              "skill": { "type": "string", "enum": ["listening", "reading", "writing", "speaking"] },
              "points": { "type": "integer", "minimum": 1 },
              "instructions": { "type": "string", "minLength": 1 },
              "sourceText": { "type": "string", "description": "Passage or transcript this section is based on, if applicable." },
              "questions": {
                "type": "array",
                "items": { "$ref": "#/definitions/question" },
                "description": "Present for auto-gradable sections (listening/reading). Omit for open written/oral production sections, which are graded via the answerKeyNotes field instead."
              },
              "answerKeyNotes": { "type": "string", "description": "Open-ended grading guidance for written/oral production sections." }
            }
          }
        }
      }
    },

    "selfReflection": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },

    "completionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "content": { "type": "string", "minLength": 1, "description": "The 'Chapter Complete' closing statement, including the bridge to the next chapter." }
      }
    }
  },
  "definitions": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "prompt", "correctAnswer", "explanation"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["multiple_choice", "true_false", "fill_blank", "matching", "ordering", "short_answer", "translation"]
        },
        "prompt": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left", "right"],
            "properties": { "left": { "type": "string" }, "right": { "type": "string" } }
          }
        },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctAnswer": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["left", "right"],
                "properties": { "left": { "type": "string" }, "right": { "type": "string" } }
              }
            }
          ]
        },
        "explanation": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "multiple_choice" } } },
          "then": { "required": ["options"] }
        },
        {
          "if": { "properties": { "type": { "const": "true_false" } } },
          "then": { "required": ["options"] }
        },
        {
          "if": { "properties": { "type": { "const": "matching" } } },
          "then": { "required": ["pairs"] }
        },
        {
          "if": { "properties": { "type": { "const": "ordering" } } },
          "then": { "required": ["items"] }
        }
      ]
    }
  }
}
