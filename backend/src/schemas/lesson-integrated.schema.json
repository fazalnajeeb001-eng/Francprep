{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://francprep.com/schemas/lesson-integrated.schema.json",
  "title": "FrancPrep Lesson 7 - Integrated Practice",
  "description": "Shape for every chapter's Lesson 7 (Integrated Practice). Structurally different from Lessons 1-6: no Vocabulary or Grammar sections; Reading and Listening share one combined scene and one combined comprehension-question set.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lessonId", "chapterId", "level", "title", "anchorSkill", "durationMinutes",
    "objectives", "grammarFocus", "vocabularyFocus",
    "warmUp", "scene", "comprehensionQuestions", "speaking", "writing",
    "practiceExercises", "miniReview", "selfAssessment"
  ],
  "properties": {
    "lessonId": { "type": "string" },
    "chapterId": { "type": "string" },
    "level": { "type": "string", "enum": ["A0", "A1", "A2", "B1", "B2", "C1", "C2"] },
    "title": { "type": "string" },
    "anchorSkill": { "type": "string", "const": "integrated" },
    "durationMinutes": { "type": "integer", "minimum": 5, "maximum": 90 },
    "objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "grammarFocus": { "type": "string", "description": "Consolidation statement — no new grammar, references what's being combined from Lessons 1-6." },
    "vocabularyFocus": { "type": "string", "description": "Consolidation statement, not new vocabulary." },

    "warmUp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": { "content": { "type": "string", "minLength": 1 } }
    },

    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "text"],
      "description": "The single shared dialogue/passage that doubles as both the Reading and Listening source for this lesson.",
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "translation": { "type": "string" },
        "audioUrl": { "type": "string" }
      }
    },

    "comprehensionQuestions": {
      "type": "array",
      "minItems": 1,
      "description": "Combined Reading+Listening comprehension questions based on the shared scene. Same question object shape as the Standard lesson schema's questionArray.",
      "items": { "$ref": "#/definitions/question" }
    },

    "speaking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roleplay"],
      "properties": {
        "roleplay": { "type": "string", "minLength": 1 },
        "extensionTask": { "type": "string" }
      }
    },

    "writing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task", "modelAnswer", "checklist"],
      "properties": {
        "task": { "type": "string", "minLength": 1 },
        "modelAnswer": { "type": "string", "minLength": 1 },
        "checklist": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },

    "practiceExercises": {
      "type": "object",
      "additionalProperties": false,
      "required": ["questions"],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/question" }
        }
      }
    },

    "miniReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": { "content": { "type": "string", "minLength": 1 } }
    },

    "selfAssessment": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "definitions": {
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "prompt", "correctAnswer", "explanation"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["multiple_choice", "true_false", "fill_blank", "matching", "ordering", "short_answer", "translation"]
        },
        "prompt": { "type": "string", "minLength": 1 },
        "options": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["left", "right"],
            "properties": { "left": { "type": "string" }, "right": { "type": "string" } }
          }
        },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "correctAnswer": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["left", "right"],
                "properties": { "left": { "type": "string" }, "right": { "type": "string" } }
              }
            }
          ]
        },
        "explanation": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "multiple_choice" } } },
          "then": { "required": ["options"] }
        },
        {
          "if": { "properties": { "type": { "const": "true_false" } } },
          "then": { "required": ["options"] }
        },
        {
          "if": { "properties": { "type": { "const": "matching" } } },
          "then": { "required": ["pairs"] }
        },
        {
          "if": { "properties": { "type": { "const": "ordering" } } },
          "then": { "required": ["items"] }
        }
      ]
    }
  }
}
