# ==================== FRONTEND (Vercel) ====================
# Your Railway backend URL (no trailing /api)
VITE_API_URL=https://francprep-backend.railway.app/api

# ==================== BACKEND (Railway) ====================
# MongoDB connection string (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/francprep

# JWT secrets (generate strong random strings)
JWT_ACCESS_SECRET=your-random-access-secret-here
JWT_REFRESH_SECRET=your-random-refresh-secret-here

# JWT expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Backend port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=https://francprep.vercel.app

# Environment
NODE_ENV=production